# ---- RateDesk environment ----
# Copy this file to `.env.local` and fill in your key.

# Enable real Claude rationale by setting ONE of these (the app runs a
# deterministic MOCK advisor if neither is set, so the UI always works):
#   ANTHROPIC_API_KEY    → sent as the `x-api-key` header  (official Anthropic style)
#   ANTHROPIC_AUTH_TOKEN → sent as `Authorization: Bearer` (proxy / relay style)
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_AUTH_TOKEN=

# OPTIONAL: point the app at a proxy/relay instead of the official endpoint.
# e.g. ANTHROPIC_BASE_URL=https://llm.kyle.pub/s/zai-coding
# ANTHROPIC_BASE_URL=

# OPTIONAL: override the model id if your endpoint expects a different name.
# ANTHROPIC_MODEL=claude-sonnet-5

# OPTIONAL (v2): Supabase for persistent storage instead of the in-memory seed.
# SUPABASE_URL=
# SUPABASE_KEY=
